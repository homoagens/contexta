# Copia questo file in .env e compila i valori reali.
# .env è git-ignorato — non committarlo mai.

# ── Provider LLM ──────────────────────────────────────────────────────────────
# "local"     = backend self-hosted (default, gratuito)
# "anthropic" = Anthropic API
# "openai"    = OpenAI API
LLM_PROVIDER=local

# ── Backend locale (LLM_PROVIDER=local) ───────────────────────────────────────
BACKEND_URL=http://<host>:19000
API_KEY=your_64_char_hex_key_here
# KEY_FILE=/path/to/api_key   # alternativa a API_KEY
LOCAL_MODEL_NAME=gemma3-4b

# ── Anthropic (LLM_PROVIDER=anthropic) ────────────────────────────────────────
# pip install anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-6

# ── OpenAI (LLM_PROVIDER=openai) ──────────────────────────────────────────────
# pip install openai
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o

# ── Auth e storage ─────────────────────────────────────────────────────────────
CONTEXTA_DB=/etc/contexta/contexta.db   # path al database SQLite
SESSION_TTL_DAYS=30                     # durata sessioni in giorni
# ADMIN_KEY=                            # chiave per admin API HTTP (opzionale)
