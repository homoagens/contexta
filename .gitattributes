# Auto-detect text files and normalize line endings to LF in the repo
* text=auto eol=lf

# Force shell scripts to LF (important for bash scripts run on Linux servers)
*.sh text eol=lf

# Force Windows-native files to CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary files — no line-ending conversion
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.pdf binary
*.zip binary
*.apk binary
*.aab binary
*.jar binary
*.class binary
*.so binary
*.dylib binary
*.dll binary
*.exe binary
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary
